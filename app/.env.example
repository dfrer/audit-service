# ==========================================
# AI Project Audit Service -- Environment Variables
# ==========================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ==========================================

# App
# The public URL of your app (use http://localhost:3000 for dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==========================================
# STRIPE (Payments)
# ==========================================
# Get these from https://dashboard.stripe.com/apikeys
# Use test keys for development, live keys for production
NEXT_PUBLIC_STRIPE_MODE=test
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXX
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXX
# Webhook secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXX
# Stripe Price IDs for each package (create in Stripe dashboard or via API)
STRIPE_PRICE_LITE=price_XXXXXXXXXXXXXXXX
STRIPE_PRICE_STANDARD=price_XXXXXXXXXXXXXXXX
STRIPE_PRICE_SCAFFOLD=price_XXXXXXXXXXXXXXXX

# ==========================================
# GITHUB (Repo access for audits)
# ==========================================
# Fine-grained PAT: https://github.com/settings/personal-access-tokens
# Scope: read-only on customer repos (with explicit allowlist)
GITHUB_PAT=ghp_XXXXXXXXXXXXXXXX

# ==========================================
# VERCEL (Deployment)
# Only needed if Hermes automates deployments via API
# ==========================================
# VERCEL_ACCESS_TOKEN=XXXXXXXXXXXXXXXX
# VERCEL_PROJECT_ID=XXXXXXXXXXXXXXXX
# VERCEL_ORG_ID=XXXXXXXXXXXXXXXX

# ==========================================
# EMAIL (Delivery notifications)
# ==========================================
# Use Resend, SendGrid, or similar. Get API key from provider.
# RESEND_API_KEY=re_XXXXXXXXXXXXXXXX
# EMAIL_FROM=noreply@yourdomain.com

# ==========================================
# DATABASE (Optional -- local implementation is default)
# ==========================================
# For Supabase/Postgres, uncomment and fill in:
# DATABASE_URL=postgresql://user:password@host:5432/auditdb
# SUPABASE_URL=https://XXXXXXXXX.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=XXXXXXXXXXXXXXXX

# ==========================================
# STORAGE (Report/PDF delivery artifacts)
# ==========================================
# Local filesystem path for dev. For production, use S3.
# STORAGE_DIR=./storage/deliveries
# For S3:
# AWS_ACCESS_KEY_ID=XXXXXXXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXX
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=your-bucket-name

# ==========================================
# MONITORING (Optional)
# ==========================================
# SENTRY_DSN=https://XXXXXXXXXXXXXXXX
